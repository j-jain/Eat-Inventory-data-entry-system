# ---- Database ----
# Production: a Neon Postgres connection string (pooled). Leave BLANK locally to use
# the in-process PGlite fallback (no external DB needed for dev/verification).
DATABASE_URL=

# Local PGlite data directory (used only when DATABASE_URL is empty)
PGLITE_DIR=./.pglite-data

# ---- Auth ----
# 32+ char random secret for signing/encrypting the session cookie
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars
# Server-side pepper mixed into PIN hashes (rotate carefully)
PIN_PEPPER=change-me-too-another-random-string

# ---- Zoho (READ-ONLY in v1) ----
# Reuse the same Zoho app + refresh token as eat-os (EATOS_ZOHO_*).
ZOHO_ENABLED=false
ZOHO_DC=in
ZOHO_ORG_ID=60009263912
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
